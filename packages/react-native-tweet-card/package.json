{
  "name": "react-native-tweet-card",
  "version": "1.0.6",
  "description": "Embed tweets in React Native. Based on vercel/react-tweet (MIT).",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "react-native-svg": "*"
  },
  "optionalPeerDependencies": {
    "expo-image": "*",
    "expo-web-browser": "*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react-native-svg": "*",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ertugrulemrecihan/react-native-tweet-card.git"
  },
  "homepage": "https://github.com/ertugrulemrecihan/react-native-tweet-card#readme"
}
